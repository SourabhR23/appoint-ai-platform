# ──────────────────────────────────────────────────────────────────────────────
# AI Appointment Agent Platform — Environment Variables Template
# Copy to .env and fill in real values.
# NEVER commit .env — only commit .env.example
# ──────────────────────────────────────────────────────────────────────────────

APP_ENV=development
APP_NAME="AI Appointment Platform"
DEBUG=true
SECRET_KEY=CHANGE_ME_MINIMUM_32_CHARS_RANDOM_STRING

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → Database → Connection string
# Use the "URI" format, replace [YOUR-PASSWORD] with your DB password
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get from: Upstash console → your Redis DB → Details → rediss:// URL
# Note: Upstash uses TLS (rediss://) — the extra 's' is correct
REDIS_URL=rediss://default:[YOUR-PASSWORD]@[YOUR-ENDPOINT].upstash.io:6379
CELERY_BROKER_URL=rediss://default:[YOUR-PASSWORD]@[YOUR-ENDPOINT].upstash.io:6379/0
CELERY_RESULT_BACKEND=rediss://default:[YOUR-PASSWORD]@[YOUR-ENDPOINT].upstash.io:6379/1

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=eyJ...          # "service_role" key (keep secret)
SUPABASE_JWT_SECRET=your-jwt-secret  # Settings → API → JWT Secret

# ── LLM Provider (EuriAI — OpenAI-compatible) ────────────────────────────────
# Get from: EuriAI dashboard → API Keys
OPENAI_API_KEY=your-euriai-api-key
OPENAI_BASE_URL=https://api.euron.one/api/v1/euri
OPENAI_MODEL=gpt-4.1

# ── Twilio (SMS + WhatsApp notifications) ────────────────────────────────────
# Get from: twilio.com → Console Dashboard
# Leave as dummy values if skipping notifications for now
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_FROM=+1234567890
TWILIO_WHATSAPP_FROM=+14155238886

# ── SMTP Email (Gmail) ────────────────────────────────────────────────────────
# Uses Python stdlib smtplib — no external email provider needed.
# Setup: Gmail → Security → 2-Step Verification → App Passwords → generate 16-char password
# Leave blank if skipping email for now (tenant can configure their own via Channel Setup)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # 16-char Gmail App Password
SMTP_FROM_NAME=AppointAI

# ── Google Calendar (optional — Phase 2) ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/google/callback

# ── Stripe (optional — Phase 2 billing) ──────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_CHAT=100
RATE_LIMIT_BOOKING=30
RATE_LIMIT_NOTIFICATION=60

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Trial ─────────────────────────────────────────────────────────────────────
TRIAL_DAYS=14
TRIAL_MAX_EXECUTIONS=100

# ── Platform Admin ────────────────────────────────────────────────────────────
# Used for the super admin portal login at /admin-login
ADMIN_EMAIL=admin@appointai.in
# Generate hash: python -c "import bcrypt; h=bcrypt.hashpw(b'YourPassword',bcrypt.gensalt()).decode(); print(h)"
ADMIN_PASSWORD_HASH=
